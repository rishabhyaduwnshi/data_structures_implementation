{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build cpp",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++17",
        "-g",
        "-I${workspaceFolder}/include",
        "src/main.cpp",
        "src/LinkedList.cpp",
        "src/Stack.cpp",
        "src/CircularQueue.cpp",
        "-o",
        "build/main"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}